{
  "name": "fox-blender-queue",
  "version": "0.1.0",
  "description": "A Blender render queue manager",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "keywords": ["blender", "render", "queue"],
  "author": {
    "name": "Shiretsuna",
    "email": "shiretsuna@users.noreply.github.com"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.5.2",
    "vite": "^5.3.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.fox.blender-queue",
    "productName": "Fox Blender Queue",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-windows-setup.${ext}"
    },
    "mac": {
      "artifactName": "${productName}-${version}-macos-${arch}.${ext}",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "linux": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "Shiretsuna",
      "repo": "fox-blender-queue"
    }
  }
}
